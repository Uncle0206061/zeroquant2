      }
    ]
  },
  "env": {
    "NAS_PATH": "\\\\100.65.205.77\\home",
    "DATA_PATH": "D:\\ZeroQuant2\\data",
    "POSTGRES_HOST": "localhost",
    "POSTGRES_PORT": "5432",
    "REDIS_HOST": "localhost",
    "REDIS_PORT": "6379"
  },
  "paths": {
    "inbox": "tasks/dataofficer/inbox",
    "done": "tasks/dataofficer/done",
    "docs": "docs",
    "src": "src"
  }
}