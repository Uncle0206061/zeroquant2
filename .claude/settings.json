{
  "project": {
    "name": "ZeroQuant2",
    "description": "A股量化辅助决策平台",
    "path": "D:/ZeroQuant2"
  },
  "permissions": {
    "allow": [
      "Bash:gofmt*",
      "Bash:go vet*",
      "Bash:python*",
      "Bash:pip*",
      "Bash:uv*"
    ],
    "deny": [
      "Bash:rm -rf*",
