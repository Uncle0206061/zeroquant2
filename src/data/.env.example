# ZeroQuant 2.0 — Python 数据服务环境变量
# 复制此文件为 .env 并填入实际值

# 服务端口
DATA_SERVICE_PORT=8081

# PostgreSQL（data 库，data_ 表前缀）
DATABASE_URL=postgresql://postgres:password@localhost:5432/data

# Redis（data: key 前缀）
REDIS_URL=redis://localhost:6379/1

# 数据源
TUSHARE_TOKEN=your_tushare_token_here
AKSHARE_ENABLED=true
TUSHARE_ENABLED=false
LEVEL2_ENABLED=false

# Level-2 WebSocket
LEVEL2_WS_URL=ws://your-level2-server:port
LEVEL2_HEARTBEAT=10
LEVEL2_MAX_RECONNECT=10
LEVEL2_RECONNECT_INTERVAL=2